# Supabase project (client-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-publishable-key

# Service role key — server-only, never exposed to browser.
# Get from Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin bootstrap secret is stored in the database (private.app_secrets),
# NOT here. Enter it on the hidden /admin-setup page to grant yourself admin.
